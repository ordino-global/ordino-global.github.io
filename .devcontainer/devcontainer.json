{
  "name": "ordino docs (Jekyll)",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.3",
  "postCreateCommand": "bundle install",
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Jekyll",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "files.eol": "\n"
      }
    }
  }
}
