{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll: build",
      "type": "shell",
      "command": "bundle exec jekyll build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Jekyll: build (strict)",
      "type": "shell",
      "command": "bundle exec jekyll build --trace --strict_front_matter",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Jekyll: serve",
      "type": "shell",
      "command": "bundle exec jekyll serve --host 0.0.0.0 --livereload",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "jekyll",
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Server address:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
